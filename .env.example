# LINE Messaging API (LINE Developers Console → Messaging API)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Google Sheet FAQ — File → Share → Publish to web → CSV
SHEET_CSV_URL=

# ===== Google Calendar (OAuth) =====
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
# Authorized redirect URI: https://<your-domain>/api/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# ได้จากการเปิด /api/google/auth ครั้งเดียว (ดู README)
GOOGLE_OAUTH_REFRESH_TOKEN=
# ปฏิทินที่จะใช้ (ดีฟอลต์ primary = ปฏิทินหลักของบัญชีที่ authorize)
GOOGLE_CALENDAR_ID=primary
# โซนเวลา (ดีฟอลต์ Asia/Bangkok)
TIMEZONE=Asia/Bangkok
